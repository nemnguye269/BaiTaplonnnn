@model WebKhoaHoc.Models.KhoaHoc

@{
    ViewData["Title"] = "Chi tiết khóa học";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 font-weight-bold text-primary">Thông tin khóa học: @Model.TenKhoaHoc</h5>
                    <a asp-action="Index" class="btn btn-sm btn-secondary shadow-sm">
                        <i class="fas fa-arrow-left fa-sm text-white-50"></i> Quay lại danh sách
                    </a>
                </div>

                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center">
                            <div class="p-3 border rounded bg-light">
                                @* SỬA TẠI ĐÂY: Thêm /courses/ vào đường dẫn src *@
                                @if (!string.IsNullOrEmpty(Model.HinhAnh))
                                {
                                    <img src="~/images/courses/@Model.HinhAnh" class="img-fluid rounded shadow-sm" alt="@Model.TenKhoaHoc" style="max-height: 250px;" />
                                }
                                else
                                {
                                    @* Đảm bảo bạn có file default.jpg trong wwwroot/images/ *@
                                    <img src="~/images/default.jpg" class="img-fluid rounded shadow-sm" alt="No Image" style="max-height: 250px;" />
                                }
                            </div>
                        </div>

                        <div class="col-md-8">
                            <table class="table table-hover">
                                <tbody>
                                    <tr>
                                        <th style="width: 30%">Mã khóa học:</th>
                                        <td>#@Model.Id</td>
                                    </tr>
                                    <tr>
                                        <th>Tên khóa học:</th>
                                        <td class="font-weight-bold text-dark">@Model.TenKhoaHoc</td>
                                    </tr>
                                    <tr>
                                        <th>Học phí:</th>
                                        <td class="text-danger font-weight-bold">
                                            @Model.GiaTien.ToString("N0") VNĐ
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Mô tả chi tiết:</th>
                                        <td>
                                            <div class="text-muted" style="line-height: 1.6;">
                                                @(string.IsNullOrEmpty(Model.MoTa) ? "Chưa có mô tả cho khóa học này." : Model.MoTa)
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <div class="mt-4">
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4">
                                    <i class="fas fa-edit"></i> Chỉnh sửa thông tin
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>