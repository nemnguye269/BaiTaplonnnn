@model IEnumerable<WebKhoaHoc.Models.KhoaHoc>

@{
    ViewData["Title"] = "Quản lý khóa học";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-1">Quản lý khóa học</h2>
        <p class="text-muted small">Danh sách các khóa học bạn đang quản lý trên hệ thống</p>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm hover-scale">
        <i class="fa-solid fa-plus me-2"></i>Thêm khóa học mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive bg-white rounded-4 shadow-sm p-3">
    <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
            <tr>
                <th class="border-0 rounded-start ps-3">Hình ảnh</th>
                <th class="border-0">Tên khóa học</th>
                <th class="border-0">Danh mục</th>
                <th class="border-0 text-end pe-3">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center py-5 text-muted">
                        <i class="fa-solid fa-inbox fs-1 d-block mb-3 opacity-25"></i>
                        Chưa có khóa học nào được tạo.
                    </td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td class="ps-3">
                        <img src="~/images/@item.HinhAnh" class="rounded-3 shadow-sm" width="80" height="50" style="object-fit: cover;" 
                             onerror="this.src='https://placehold.co/80x50?text=No+Image'">
                    </td>
                    <td>
                        <div class="fw-bold text-dark">@item.TenKhoaHoc</div>
                        <div class="text-muted x-small" style="font-size: 0.75rem;">ID: #@item.Id</div>
                    </td>
                    <td>
                        <span class="badge bg-soft-primary text-primary border border-primary-subtle rounded-pill px-3">
                            @(item.DanhMuc?.TenDanhMuc ?? "Chưa phân loại")
                        </span>
                    </td>
                    <td class="text-end pe-3">
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-circle nav-icon-btn" title="Sửa">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-circle nav-icon-btn" title="Chi tiết">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-circle nav-icon-btn" title="Xóa">
                                <i class="fa-solid fa-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Styles {
    <style>
        .bg-soft-primary { background-color: rgba(79, 70, 229, 0.1); }
        .table thead th { font-weight: 600; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.5px; color: #64748b; }
        .nav-icon-btn { width: 34px !important; height: 34px !important; }
        .table-hover tbody tr:hover { background-color: #f8fafc; cursor: pointer; }
    </style>
}