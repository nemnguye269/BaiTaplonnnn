@{
    ViewData["Title"] = "Thanh toán thành công";
}

<div class="container py-5 text-center mt-5">
    <div class="mb-4 text-success" style="font-size: 5rem;">
        <i class="fa-regular fa-circle-check"></i>
    </div>
    <h1 class="fw-bold text-dark mb-3">Thanh toán thành công!</h1>
    <p class="text-secondary mb-5 fs-5">Chúc mừng bạn đã sở hữu khóa học. Hãy bắt đầu hành trình chinh phục kiến thức ngay thôi.</p>

    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold">Về trang chủ</a>
        <a asp-controller="Home" asp-action="MyCourses" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm">
            <i class="fa-solid fa-play me-2"></i>Vào học ngay
        </a>
    </div>
</div>