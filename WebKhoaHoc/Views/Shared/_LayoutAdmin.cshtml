<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin WebKhoaHoc</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    
    <style>
        :root {
            --sidebar-width: 280px;
            --primary-color: #4361ee;
            --sidebar-bg: #0f172a;
            --content-bg: #f8fafc;
            --text-muted: #64748b;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--content-bg);
            color: #1e293b;
            overflow-x: hidden;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Styling */
        .admin-sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background-color: var(--sidebar-bg);
            z-index: 1000;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 4px 0 10px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 2rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 800;
            font-size: 1.4rem;
            letter-spacing: -0.5px;
        }

        .nav-admin { padding: 0 1rem; flex-grow: 1; }

        .nav-label {
            color: #475569;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 1.5rem 1rem 0.5rem;
        }

        .nav-admin-link {
            display: flex;
            align-items: center;
            padding: 0.875rem 1.25rem;
            color: #94a3b8;
            text-decoration: none;
            border-radius: 12px;
            margin-bottom: 0.5rem;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .nav-admin-link:hover { color: white; background: rgba(255,255,255,0.05); }

        .nav-admin-link.active {
            background-color: var(--primary-color);
            color: white;
            box-shadow: 0 10px 15px -3px rgba(67, 97, 238, 0.3);
        }

        .nav-admin-link i { width: 1.5rem; margin-right: 1rem; font-size: 1.2rem; }

        /* Content Area */
        .admin-main {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: all 0.4s ease;
        }

        .admin-header {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            padding: 1rem 2.5rem;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 900;
        }

        .content-body { padding: 2.5rem; flex-grow: 1; }

        .user-profile-btn {
            background: #f1f5f9;
            border: none;
            padding: 0.4rem 1rem;
            border-radius: 50px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        @@media (max-width: 991px) {
            .admin-sidebar { left: calc(-1 * var(--sidebar-width)); }
            .admin-main { margin-left: 0; width: 100%; }
            .admin-sidebar.show { left: 0; }
        }
    </style>
</head>
<body>

    <aside class="admin-sidebar shadow-lg">
        <div class="sidebar-header">
            <span class="text-primary"><i class="fa-solid fa-bolt-lightning me-2"></i></span>
            WebKhoaHoc
        </div>
        
        <nav class="nav-admin">
            <div class="nav-label">Chính</div>
            <a asp-controller="AdminKhoaHoc" asp-action="Index" 
               class="nav-admin-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminKhoaHoc" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <i class="fa-solid fa-chart-line"></i> Dashboard
            </a>
            
            <div class="nav-label">Quản lý nội dung</div>
            <a asp-controller="AdminKhoaHoc" asp-action="Index" class="nav-admin-link">
                <i class="fa-solid fa-book-bookmark"></i> Khóa học
            </a>
            <a href="#" class="nav-admin-link">
                <i class="fa-solid fa-cart-shopping"></i> Đơn hàng
            </a>
            <a href="#" class="nav-admin-link">
                <i class="fa-solid fa-users"></i> Người dùng
            </a>
            
            <div class="nav-label">Hệ thống</div>
            <a href="#" class="nav-admin-link">
                <i class="fa-solid fa-gear"></i> Cài đặt
            </a>
            <div class="my-4 mx-3 border-top border-secondary opacity-25"></div>
            <a asp-controller="Home" asp-action="Index" class="nav-admin-link text-info">
                <i class="fa-solid fa-rocket"></i> Về trang chủ
            </a>
        </nav>
    </aside>

    <div class="admin-main">
        <header class="admin-header shadow-sm">
            <div class="d-flex align-items-center">
                <button id="sidebarToggle" class="btn btn-sm btn-light d-lg-none me-3">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <h6 class="fw-bold mb-0 text-dark">@ViewData["Title"]</h6>
            </div>
            
            <div class="d-flex align-items-center gap-3">
                <div class="user-profile-btn shadow-sm">
                    <img src="https://ui-avatars.com/api/?name=@(User.Identity.Name ?? "Admin")&background=4361ee&color=fff" 
                         class="rounded-circle" width="28" height="28" alt="avatar">
                    <span class="small d-none d-sm-inline">@User.Identity.Name</span>
                </div>
                
                @* Form Đăng xuất bảo mật *@
                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-light btn-sm rounded-circle text-danger p-2 shadow-sm" title="Đăng xuất">
                        <i class="fa-solid fa-power-off"></i>
                    </button>
                </form>
            </div>
        </header>

        <main class="content-body">
            @RenderBody()
        </main>

        <footer class="py-4 px-5 text-muted small mt-auto border-top bg-white">
            <div class="container-fluid d-flex justify-content-between align-items-center">
                <span>&copy; 2026 <b>WebKhoaHoc</b>. All rights reserved.</span>
                <div class="d-flex gap-4">
                    <a href="#" class="text-decoration-none text-muted">Hỗ trợ</a>
                    <a href="#" class="text-decoration-none text-muted">Chính sách</a>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function() {
            // Toggle Sidebar
            $("#sidebarToggle").click(function() {
                $(".admin-sidebar").toggleClass("show");
            });

            // Hiển thị thông báo thành công
            @if (TempData["Success"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: '@TempData["Success"]',
                    timer: 2500,
                    showConfirmButton: false,
                    toast: true,
                    position: 'top-end'
                });
                </text>
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>