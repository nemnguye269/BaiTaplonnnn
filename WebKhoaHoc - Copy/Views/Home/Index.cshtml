@model IEnumerable<WebKhoaHoc.Models.KhoaHoc>
@{
    ViewData["Title"] = "Trang Chủ - EduLearn";
}

<div class="row g-4">
    <div class="col-lg-3 d-none d-lg-block">
        <div class="bg-white rounded-4 p-4 shadow-sm border sticky-top" style="top: 90px; z-index: 900;">
            <div class="d-flex align-items-center gap-2 mb-4 pb-3 border-bottom">
                <i class="fa-solid fa-filter text-primary"></i>
                <h5 class="fw-bold m-0">Bộ lọc</h5>
            </div>
            <form asp-controller="Home" asp-action="Index" method="get">
                <div class="mb-4">
                    <h6 class="fw-bold mb-3 small text-uppercase text-secondary ls-1">Tìm tên khóa học</h6>
                    <div class="input-group input-group-sm">
                        <input type="text" name="searchString" class="form-control border-light bg-light rounded-start-pill" 
                               placeholder="Nhập từ khóa..." value="@ViewData["CurrentFilter"]">
                        <button class="btn btn-primary rounded-end-pill" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="fw-bold mb-3 small text-uppercase text-secondary ls-1">Giá khóa học</h6>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="priceFilter" id="priceAll" value="" @(ViewData["PriceFilter"] == null || ViewData["PriceFilter"].ToString() == "" ? "checked" : "")>
                        <label class="form-check-label" for="priceAll">Tất cả</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="priceFilter" id="pricePaid" value="paid" @(ViewData["PriceFilter"]?.ToString() == "paid" ? "checked" : "")>
                        <label class="form-check-label" for="pricePaid">Có phí</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="priceFilter" id="priceFree" value="free" @(ViewData["PriceFilter"]?.ToString() == "free" ? "checked" : "")>
                        <label class="form-check-label" for="priceFree">Miễn phí</label>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="fw-bold mb-3 small text-uppercase text-secondary ls-1">Sắp xếp theo</h6>
                    <select name="sortOrder" class="form-select form-select-sm border-light bg-light rounded-pill" onchange="this.form.submit()">
                        <option value="">Mới nhất</option>
                        <option value="Price_Asc" selected="@(ViewData["CurrentSort"]?.ToString() == "Price_Asc")">Giá thấp đến cao</option>
                        <option value="Price_Desc" selected="@(ViewData["CurrentSort"]?.ToString() == "Price_Desc")">Giá cao đến thấp</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary w-100 rounded-pill mt-2 fw-bold shadow-sm py-2 hover-scale">Áp dụng</button>
                <a asp-action="Index" class="btn btn-link text-decoration-none text-secondary w-100 mt-2 small fw-bold text-center d-block">Xóa lọc</a>
            </form>
        </div>
    </div>

    <div class="col-lg-9">
        <div id="bannerCarousel" class="carousel slide mb-5 shadow-sm rounded-4 overflow-hidden" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active" data-bs-interval="5000">
                    <img src="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?auto=format&fit=crop&w=1350&q=80" class="d-block w-100" style="height: 350px; object-fit: cover;">
                    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(135deg, rgba(79, 70, 229, 0.9) 0%, rgba(147, 51, 234, 0.7) 100%);"></div>
                    <div class="carousel-caption h-100 d-flex flex-column justify-content-center align-items-start text-start p-5 top-0">
                        <span class="badge bg-white text-primary mb-3 px-3 py-2 rounded-pill fw-bold">CHÀO MỪNG BẠN</span>
                        <h1 class="display-6 fw-bold mb-3">Học Lập Trình Thực Chiến</h1>
                        <p class="lead mb-4 opacity-75">Nâng tầm kỹ năng cùng đội ngũ EduLearn.</p>
                        <a href="#danhSachKhoaHoc" class="btn btn-light rounded-pill px-4 py-2 fw-bold text-primary shadow-sm">Khám phá ngay</a>
                    </div>
                </div>
            </div>
        </div>

        <h3 class="fw-bold mb-4" id="danhSachKhoaHoc">Khóa học dành cho bạn</h3>

        <div class="row g-4 mb-5">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col-md-6 col-xl-4 d-flex align-items-stretch">
                        <div class="card w-100 border-0 shadow-sm rounded-4 overflow-hidden hover-card transition-all">
                            <div class="position-relative" style="padding-top: 56.25%;">
                                <a asp-action="Details" asp-route-id="@item.Id">
                                    <img src="@(string.IsNullOrEmpty(item.HinhAnh) || item.HinhAnh == "default.jpg" 
                                      ? "https://images.unsplash.com/photo-1587620962725-abab7fe55159?q=80&w=800" 
                                     : Url.Content("~/images/courses/" + item.HinhAnh))" 
                                     class="position-absolute top-0 start-0 w-100 h-100 object-fit-cover" 
                                     alt="@item.TenKhoaHoc"
                                     onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1587620962725-abab7fe55159?q=80&w=800';">
                                </a>
                                <div class="position-absolute top-0 end-0 m-2">
                                    <span class="badge bg-white text-dark shadow-sm rounded-pill fw-bold small">
                                        <i class="fa-solid fa-star text-warning me-1"></i>4.9
                                    </span>
                                </div>
                            </div>

                            <div class="card-body d-flex flex-column p-3">
                                <div class="mb-2">
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2 py-1 small fw-normal">
                                        @(item.DanhMuc?.TenDanhMuc ?? "Chưa phân loại")
                                    </span>
                                </div>
                                <h6 class="card-title fw-bold text-dark mb-3 text-truncate-2" style="height: 45px;">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">@item.TenKhoaHoc</a>
                                </h6>
                                
                                <div class="d-flex align-items-center justify-content-between mt-auto">
                                    <div>
                                        @if (item.GiaTien > 0)
                                        {
                                            <div class="text-primary fw-bold fs-5">@item.GiaTien.ToString("N0") đ</div>
                                        }
                                        else
                                        {
                                            <div class="text-success fw-bold fs-5">Miễn phí</div>
                                        }
                                    </div>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary rounded-pill btn-sm px-3 fw-bold"> Chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <img src="https://cdn-icons-png.flaticon.com/512/7486/7486744.png" width="100" class="mb-3 opacity-50">
                    <h5 class="text-secondary">Không tìm thấy khóa học nào khớp với bộ lọc.</h5>
                    <a asp-action="Index" class="btn btn-primary rounded-pill mt-3">Quay lại trang chính</a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1rem !important; }
    .hover-card:hover { transform: translateY(-5px); transition: 0.3s; box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
    .text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .object-fit-cover { object-fit: cover; }
    .hover-scale:hover { transform: scale(1.02); transition: 0.2s; }
</style>