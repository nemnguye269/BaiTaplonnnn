@model IEnumerable<WebKhoaHoc.Models.KhoaHoc>
@{
    ViewData["Title"] = "Khóa học của tôi";
}

<div class="container py-5">
    <div class="row mb-5 align-items-end">
        <div class="col-md-6">
            <h2 class="fw-bold text-dark mb-1">
                <i class="fa-solid fa-book-open-reader text-primary me-2"></i>Khóa học của tôi
            </h2>
            <p class="text-secondary mb-0 ps-1">Tiếp tục hành trình chinh phục tri thức của bạn!</p>
        </div>
        <div class="col-md-6">
            <form asp-action="MyCourses" method="get">
                <div class="input-group shadow-sm rounded-pill overflow-hidden border bg-white mt-3 mt-md-0">
                    <span class="input-group-text bg-white border-0 ps-4">
                        <i class="fa-solid fa-search text-secondary"></i>
                    </span>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                           class="form-control border-0 py-2" placeholder="Tìm trong khóa học của bạn...">
                    <button class="btn btn-primary px-4 fw-bold m-1 rounded-pill" type="submit">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                // LOGIC GẮN LINK: Lấy link từ bài học đầu tiên, nếu không có thì mặc định là youtube.com
                var linkVideo = item.BaiHocs?.OrderBy(b => b.Id).FirstOrDefault(b => !string.IsNullOrEmpty(b.VideoUrl))?.VideoUrl;
                
                if (string.IsNullOrEmpty(linkVideo))
                {
                    linkVideo = "https://www.youtube.com";
                }

                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 hover-scale-sm transition-all bg-white">
                        <div class="row g-0 h-100 align-items-center">
                            <div class="col-sm-5 h-100 position-relative overflow-hidden">
                                <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "https://via.placeholder.com/400x300" : (item.HinhAnh.StartsWith("http") ? item.HinhAnh : "/images/courses/" + item.HinhAnh))"
                                     class="w-100 h-100 object-fit-cover position-absolute top-0 start-0"
                                     style="min-height: 180px;" alt="@item.TenKhoaHoc"
                                     onerror="this.src='https://via.placeholder.com/400x300'">
                                
                                <div class="position-absolute top-0 start-0 m-2">
                                    <span class="badge bg-success bg-opacity-75 backdrop-blur rounded-pill small shadow-sm">
                                        <i class="fa-solid fa-check-circle me-1"></i>Đã đăng ký
                                    </span>
                                </div>
                            </div>

                            <div class="col-sm-7">
                                <div class="card-body d-flex flex-column h-100 p-3 p-lg-4">
                                    <h5 class="card-title fw-bold text-dark text-truncate-2 mb-2" style="font-size: 1.1rem; line-height: 1.4;">
                                        @item.TenKhoaHoc
                                    </h5>
                                    
                                    <div class="mt-auto pt-3">
                                        <div class="d-flex justify-content-between small text-muted mb-1 fw-bold">
                                            <span>Tiến độ học tập</span>
                                            <span class="text-primary">65%</span>
                                        </div>
                                        <div class="progress rounded-pill mb-3 bg-light" style="height: 8px;">
                                            <div class="progress-bar bg-primary rounded-pill progress-bar-striped progress-bar-animated" role="progressbar" style="width: 65%"></div>
                                        </div>

                                        @* Nút luôn hiển thị và dẫn link Youtube *@
                                        <a href="@linkVideo" target="_blank"
                                               class="btn btn-primary w-100 rounded-pill fw-bold btn-sm py-2 shadow-sm hover-btn-up">
                                            <i class="fa-solid fa-play me-2"></i>Vào học ngay
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 rounded-4 bg-light border border-dashed border-2 mt-4">
            <div class="text-secondary mb-3 opacity-50" style="font-size: 4rem;">
                <i class="fa-solid fa-box-open"></i>
            </div>
            <h4 class="fw-bold text-dark">Bạn chưa đăng ký khóa học nào</h4>
            <p class="text-muted mb-4">Hàng ngàn kiến thức bổ ích đang chờ bạn khám phá.</p>
            <a asp-action="Index" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm hover-scale">
                <i class="fa-solid fa-compass me-2"></i>Khám phá ngay
            </a>
        </div>
    }
</div>

<style>
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .hover-scale-sm:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .backdrop-blur {
        backdrop-filter: blur(4px);
    }

    .hover-btn-up:hover {
        background-color: #0b5ed7;
        transform: translateY(-2px);
        transition: 0.2s;
    }

    .object-fit-cover {
        object-fit: cover;
    }
</style>