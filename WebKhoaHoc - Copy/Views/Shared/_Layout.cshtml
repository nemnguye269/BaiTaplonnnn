<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduLearn</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* HIỆU ỨNG CUỘN MƯỢT & NỀN */
        html { scroll-behavior: smooth; }
        body { position: relative; min-height: 100vh; background: #f8fafc; font-family: 'Segoe UI', sans-serif; overflow-x: hidden; }
        
        body::before {
            content: ""; position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: -1;
            background-image: url('https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=2070&auto=format&fit=crop');
            background-size: cover; background-position: center; filter: blur(8px) brightness(0.6); transform: scale(1.1);
        }

        .main-glass-container {
            background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(15px);
            border-radius: 24px; padding: 40px; margin-top: 30px; margin-bottom: 50px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1); border: 1px solid rgba(255, 255, 255, 0.5);
            min-height: 70vh;
        }

        .navbar-custom {
            background: rgba(255, 255, 255, 0.95) !important; backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05); box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            z-index: 1030;
        }

        .nav-icon-btn {
            width: 42px; height: 42px; display: flex; align-items: center; justify-content: center;
            border-radius: 50%; color: #64748b; transition: all 0.2s; position: relative;
        }
        .nav-icon-btn:hover { background: #f1f5f9; color: #4f46e5; transform: translateY(-2px); }
        .nav-badge { position: absolute; top: 2px; right: 2px; font-size: 0.65rem; padding: 0.35em 0.5em; transform: translate(25%, -25%); border: 2px solid white; }

        .cart-dropdown-menu { min-width: 320px; border: none; box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important; border-radius: 16px !important; padding: 20px !important; margin-top: 15px !important; }

        .footer-glass {
            background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255, 255, 255, 0.3); border-radius: 24px 24px 0 0;
            padding: 40px 0 20px 0; margin-top: auto;
        }

        #btnBackToTop {
            position: fixed; bottom: 30px; right: 30px; z-index: 999; width: 45px; height: 45px;
            border-radius: 50%; background: #4f46e5; color: white; border: none; display: none;
            align-items: center; justify-content: center; transition: 0.3s; box-shadow: 0 4px 15px rgba(79, 70, 229, 0.4);
        }
        #btnBackToTop:hover { transform: translateY(-5px); background: #4338ca; }
        
        .hover-scale { transition: transform 0.2s; }
        .hover-scale:hover { transform: scale(1.05); }
    </style>
    @* SỬA LỖI: Render Section Styles tại đây *@
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <header class="navbar-custom sticky-top py-2">
        <div class="container d-flex justify-content-between align-items-center">
            
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none d-flex align-items-center gap-2 hover-scale">
                <div class="bg-primary text-white rounded-3 d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
                    <i class="fa-solid fa-graduation-cap"></i>
                </div>
                <span class="fs-4 fw-bold text-dark">EduLearn</span>
            </a>

            <div class="d-none d-md-block flex-grow-1 mx-5" style="max-width: 400px;">
                <form asp-controller="Home" asp-action="Index" method="get">
                    <div class="input-group rounded-pill bg-light border overflow-hidden">
                        <input class="form-control border-0 bg-transparent ps-3 shadow-none" type="search" name="searchString" placeholder="Tìm khóa học bạn cần...">
                        <button class="btn text-primary pe-3" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
                    </div>
                </form>
            </div>

            <div class="d-flex align-items-center gap-2 gap-md-3">
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="dropdown">
                        <a href="#" class="nav-icon-btn text-decoration-none" id="cartDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa-solid fa-cart-shopping fs-5"></i>
                            <span class="badge rounded-pill bg-primary nav-badge" id="cart-count">0</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end cart-dropdown-menu">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-bold mb-0">Khóa học đã chọn</h6>
                                <span class="badge bg-light text-dark border" id="cart-items-label">0 mục</span>
                            </div>
                            <div class="p-3 bg-light rounded-3 mb-3 border border-dashed">
                                <div class="d-flex justify-content-between small">
                                    <span class="text-muted">Tổng cộng:</span>
                                    <span class="fw-bold text-primary fs-5" id="cart-total">0 đ</span>
                                </div>
                            </div>
                            <div class="d-grid">
                                <a asp-controller="GioHang" asp-action="Index" class="btn btn-primary rounded-pill fw-bold py-2 shadow-sm">
                                    Xem giỏ hàng <i class="fa-solid fa-arrow-right ms-1 small"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center gap-2 text-decoration-none p-1 rounded-pill hover-bg-light" data-bs-toggle="dropdown">
                            <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=4f46e5&color=fff" class="rounded-circle border border-2 border-white shadow-sm" width="36" height="36">
                            <i class="fa-solid fa-chevron-down text-muted small d-none d-md-block"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 p-2 mt-2">
                            <li class="px-3 py-2 border-bottom mb-2">
                                <div class="fw-bold text-dark">@User.Identity.Name</div>
                                <div class="small text-muted"><i class="fa-solid fa-circle text-success me-1" style="font-size: 0.5rem;"></i> Đang trực tuyến</div>
                            </li>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="dropdown-header text-uppercase small fw-bold">Quản trị</li>
                                <li>
                                    <a class="dropdown-item rounded-3 py-2" asp-controller="AdminThongKe" asp-action="Index">
                                        <i class="fa-solid fa-gauge-high me-2 text-primary"></i>Dashboard
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item rounded-3 py-2" asp-controller="AdminKhoaHoc" asp-action="Index">
                                        <i class="fa-solid fa-book me-2 text-success"></i>Quản lý Khóa học
                                    </a>
                                </li>
                                <hr class="dropdown-divider">
                            }
                            @* Chỉ hiển thị Khóa học của tôi nếu người dùng KHÔNG PHẢI là Admin *@
                            @if (!User.IsInRole("Admin"))
                            {
                                <li>
                                    <a class="dropdown-item rounded-3 py-2" asp-controller="Home" asp-action="MyCourses">
                                        <i class="fa-solid fa-video me-2 text-warning"></i>Khóa học của tôi
                                    </a>
                                </li>
                            }

                            <li><a class="dropdown-item rounded-3 py-2" href="#"><i class="fa-regular fa-user me-2"></i>Hồ sơ cá nhân</a></li>
                          
                            
                            <li class="mt-2 pt-2 border-top">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item text-danger fw-bold rounded-3 py-2"><i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm hover-scale">Đăng nhập</a>
                }
            </div>
        </div>
    </header>

    <div class="container">
        <main role="main" class="main-glass-container animate__animated animate__fadeIn">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-glass">
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-lg-4">
                    <h5 class="fw-bold mb-3 text-primary">EduLearn</h5>
                    <p class="text-muted small mb-0">Nền tảng học trực tuyến hàng đầu, mang kiến thức chuyên sâu đến mọi người.</p>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="fw-bold mb-3">Liên kết</h6>
                    <ul class="list-unstyled small text-muted">
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted">Về chúng tôi</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Khóa học</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-3">
                    <h6 class="fw-bold mb-3">Hỗ trợ</h6>
                    <ul class="list-unstyled small text-muted">
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted">Điều khoản dịch vụ</a></li>
                        <li class="mb-2"><a href="#" class="text-decoration-none text-muted">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h6 class="fw-bold mb-3">Theo dõi</h6>
                    <div class="d-flex gap-2">
                        <a href="#" class="nav-icon-btn"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#" class="nav-icon-btn"><i class="fa-brands fa-youtube"></i></a>
                        <a href="#" class="nav-icon-btn"><i class="fa-brands fa-linkedin-in"></i></a>
                    </div>
                </div>
            </div>
            <div class="border-top pt-3 text-center">
                <p class="text-muted mb-0" style="font-size: 0.8rem;">&copy; @DateTime.Now.Year - EduLearn. Hệ thống quản lý khóa học trực tuyến.</p>
            </div>
        </div>
    </footer>

    <button id="btnBackToTop" onclick="scrollToTop()"><i class="fa-solid fa-arrow-up"></i></button>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/lenis@1.0.45/dist/lenis.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const lenis = new Lenis();
        function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
        requestAnimationFrame(raf);

        function updateCart() {
            $.get('/GioHang/GetCartSummary', function (data) {
                $('#cart-count').text(data.count);
                $('#cart-total').text(data.totalAmount);
                $('#cart-items-label').text(data.count + ' mục');
            });
        }

        $(document).ready(function() {
            @if (User.Identity.IsAuthenticated) {
                <text>updateCart();</text>
            }
            
            window.onscroll = function() {
                if (document.documentElement.scrollTop > 300) {
                    $('#btnBackToTop').fadeIn().css('display', 'flex');
                } else {
                    $('#btnBackToTop').fadeOut();
                }
            };
        });

        function scrollToTop() { lenis.scrollTo(0, { lerp: 0.1 }); }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>