@model WebKhoaHoc.Models.KhoaHoc

@{
    ViewData["Title"] = "Chỉnh Sửa Khóa Học";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    /* Dùng chung style Admin */
    .admin-container {
        display: flex;
        background-color: #f8fafc;
        min-height: calc(100vh - 80px);
        margin-top: -1.5rem;
    }

    .sidebar {
        width: 280px;
        background: white;
        border-right: 1px solid #e2e8f0;
        padding: 24px;
        display: flex;
        flex-direction: column;
    }

    .form-card {
        background: white;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        border: 1px solid #f1f5f9;
    }
</style>

<div class="admin-container rounded-4 mt-4 overflow-hidden border">
    <aside class="sidebar d-none d-lg-flex">
        <div class="mb-4 px-2"><h5 class="fw-bold text-gradient-primary">Admin Dashboard</h5></div>
        <a asp-action="Index" class="btn btn-light text-start text-secondary fw-bold rounded-3 p-3">
            <i class="fa-solid fa-arrow-left me-2"></i> Quay lại
        </a>
    </aside>

    <main class="flex-grow-1 p-4 bg-light">
        <div class="d-flex justify-content-center">
            <div class="col-md-8">
                <div class="form-card">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="fw-bold text-dark m-0">Sửa Khóa Học</h3>
                        <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill">ID: @Model.Id</span>
                    </div>

                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small">Tên Khóa Học</label>
                            <input asp-for="TenKhoaHoc" class="form-control-custom" />
                            <span asp-validation-for="TenKhoaHoc" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-secondary small">Giá Tiền</label>
                                <input asp-for="GiaTien" class="form-control-custom" type="number" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-secondary small">Link Hình Ảnh</label>
                                <input asp-for="HinhAnh" class="form-control-custom" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary small">Mô Tả</label>
                            <textarea asp-for="MoTa" class="form-control-custom" rows="4"></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill fw-bold shadow w-100">
                            <i class="fa-solid fa-save me-2"></i> Cập Nhật Thay Đổi
                        </button>
                        <div class="form-group mb-3">
                            <label asp-for="TenKhoaHoc" class="control-label fw-bold"></label>
                            <input asp-for="TenKhoaHoc" class="form-control" placeholder="Nhập tên khóa học ít nhất 10 ký tự..." />
                            <span asp-validation-for="TenKhoaHoc" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="VideoUrl" class="control-label fw-bold"></label>
                            <input asp-for="VideoUrl" class="form-control" placeholder="https://www.youtube.com/watch?v=..." />
                            <span asp-validation-for="VideoUrl" class="text-danger small"></span>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}