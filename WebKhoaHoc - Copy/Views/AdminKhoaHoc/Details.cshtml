@model WebKhoaHoc.Models.KhoaHoc

@{
    ViewData["Title"] = "Chi tiết khóa học - " + Model.TenKhoaHoc;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.TenKhoaHoc</li>
        </ol>
    </nav>

    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="card-body p-4 p-lg-5">
            <div class="row">
                <div class="col-md-5 mb-4 mb-md-0">
                    <div class="position-relative">
                        @if (!string.IsNullOrEmpty(Model.HinhAnh))
                        {
                            @* Sửa đường dẫn ảnh để đảm bảo load đúng từ wwwroot *@
                            <img src="~/images/courses/@Model.HinhAnh" 
                                 class="img-fluid rounded-4 shadow-sm w-100" 
                                 alt="@Model.TenKhoaHoc" 
                                 style="aspect-ratio: 16/9; object-fit: cover;"
                                 onerror="this.src='https://placehold.co/800x450?text=EduLearn+Course'" />
                        }
                        else
                        {
                            <img src="https://placehold.co/800x450?text=No+Image" class="img-fluid rounded-4 shadow" alt="No Image" />
                        }
                    </div>
                    
                    <div class="mt-4 d-grid gap-2">
                        <div class="p-3 bg-light rounded-4 border text-center">
                            <span class="text-muted d-block small mb-1">Học phí trọn gói</span>
                            <h3 class="text-primary fw-bold mb-0">@(Model.GiaTien > 0 ? Model.GiaTien.ToString("N0") + " đ" : "Miễn phí")</h3>
                        </div>
                        @* Gọi hàm Ajax đã viết trong Controller *@
                        <button onclick="handleRegister(@Model.Id)" class="btn btn-primary btn-lg rounded-pill shadow-sm fw-bold py-3 hover-scale">
                            <i class="fas fa-shopping-cart me-2"></i> ĐĂNG KÝ NGAY
                        </button>
                    </div>
                </div>

                <div class="col-md-7 ps-md-5">
                    <span class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill mb-3">
                        <i class="fa-solid fa-tag me-1"></i> @(Model.DanhMuc?.TenDanhMuc ?? "Khóa học")
                    </span>
                    <h1 class="display-6 fw-bold text-dark mb-3">@Model.TenKhoaHoc</h1>
                    
                    <div class="mb-4">
                        <h5 class="fw-bold border-bottom pb-2">Giới thiệu khóa học</h5>
                        <p class="text-secondary" style="line-height: 1.8; text-align: justify;">
                            @(string.IsNullOrEmpty(Model.MoTa) ? "Đang cập nhật nội dung chi tiết cho khóa học này..." : Model.MoTa)
                        </p>
                    </div>

                    <div class="mt-4">
                        <h5 class="fw-bold border-bottom pb-2">
                            <i class="fas fa-list-ul me-2"></i>Lộ trình học tập
                        </h5>
                        <div class="accordion mt-3" id="courseLessons">
                            @if (Model.BaiHocs != null && Model.BaiHocs.Any())
                            {
                                int count = 1;
                                foreach (var baiHoc in Model.BaiHocs)
                                {
                                    <div class="accordion-item border-0 mb-2 shadow-sm rounded-3 overflow-hidden">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button collapsed" type="button">
                                                <i class="fas fa-play-circle me-3 text-primary"></i>
                                                Bài @count: @baiHoc.TieuDe
                                            </button>
                                        </h2>
                                    </div>
                                    count++;
                                }
                            }
                            else
                            {
                                <div class="alert alert-light text-muted border rounded-3">
                                    <i class="fas fa-info-circle me-2"></i> Danh sách bài học đang được cập nhật...
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function handleRegister(courseId) {
            $.ajax({
                url: '/GioHang/AddToCart',
                type: 'POST',
                data: { id: courseId },
                success: function (response) {
                    if (response.success) {
                        // Cập nhật Header ngay lập tức
                        if (typeof updateCart === "function") updateCart();

                        Swal.fire({
                            title: 'Thành công!',
                            text: 'Khóa học đã được thêm vào danh sách của bạn.',
                            icon: 'success',
                            timer: 2000,
                            showConfirmButton: false,
                            toast: true,
                            position: 'top-end'
                        });
                    } else {
                        // Yêu cầu đăng nhập nếu cần
                        window.location.href = '/Account/Login';
                    }
                },
                error: function () {
                    Swal.fire('Lỗi', 'Không thể kết nối máy chủ', 'error');
                }
            });
        }
    </script>
}

@section Styles {
    <style>
        .bg-soft-primary { background-color: #eef2ff; }
        .rounded-4 { border-radius: 1.25rem !important; }
        .hover-scale:hover { transform: scale(1.02); transition: 0.3s ease; }
        .accordion-button::after { display: none; }
        .accordion-button:not(.collapsed) { background-color: #f8f9fa; color: #4f46e5; }
        .accordion-button { font-weight: 500; border: none; }
    </style>
}