@model IEnumerable<WebKhoaHoc.Models.KhoaHoc>
@{
    ViewData["Title"] = "Admin Panel";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="bg-white shadow-sm p-4" style="border-radius: 24px;">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div class="d-flex align-items-center gap-2">
            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                <i class="fa-solid fa-user-shield"></i>
            </div>
            <div>
                <h5 class="fw-bold mb-0">Admin Panel</h5>
                <small class="text-muted">Hệ thống quản trị</small>
            </div>
        </div>
        <nav class="d-flex gap-4">
            <a asp-action="Index" class="text-primary fw-bold text-decoration-none border-bottom border-primary border-2">Dashboard</a>
            <a asp-action="Index" class="text-secondary fw-bold text-decoration-none">Quản lý khóa học</a>
            <a href="#" class="text-secondary fw-bold text-decoration-none">Đơn hàng <span class="badge bg-danger">@ViewBag.TotalOrders</span></a>
        </nav>
    </div>

    <div class="row mb-4">
        <div class="col-md-6 border-end">
            <small class="text-uppercase text-muted fw-bold small">Doanh thu dự kiến</small>
            <h3 class="fw-bold text-dark">@string.Format("{0:N0}", ViewBag.TotalRevenue ?? 0) đ</h3>
        </div>
        <div class="col-md-6 ps-4">
            <small class="text-uppercase text-muted fw-bold small">Tổng khóa học</small>
            <h3 class="fw-bold text-dark">@ViewBag.TotalCourses</h3>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold text-uppercase small text-secondary">Danh sách khóa học</h6>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 btn-sm fw-bold shadow-sm">
            <i class="fa-solid fa-plus me-1"></i> THÊM MỚI
        </a>
    </div>

    <div class="table-responsive">
        <table class="table align-middle table-hover">
            <thead class="table-light">
                <tr class="small text-secondary">
                    <th>THÔNG TIN KHÓA HỌC</th>
                    <th>DANH MỤC</th>
                    <th>HỌC PHÍ</th>
                    <th class="text-end">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <img src="~/images/courses/@item.HinhAnh" class="rounded-3 shadow-sm" style="width:50px; height:50px; object-fit:cover;" onerror="this.src='https://placehold.co/100x100?text=No+Image'">
                                    <div>
                                        <div class="fw-bold text-dark" style="max-width:250px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                            @item.TenKhoaHoc
                                        </div>
                                        <small class="text-muted small">Mã: #@item.Id</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border fw-normal">@item.DanhMuc?.TenDanhMuc</span>
                            </td>
                            <td class="fw-bold text-primary">@item.GiaTien.ToString("N0") đ</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill" title="Xem chi tiết">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill" title="Chỉnh sửa">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill" title="Xóa">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>