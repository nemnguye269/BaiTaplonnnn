@model WebKhoaHoc.Models.KhoaHoc

@{
    ViewData["Title"] = "Xác nhận xóa";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    /* Xóa bỏ khoảng trắng thừa của container mặc định */
    .admin-delete-wrapper {
        background-color: #f8fafc;
        min-height: calc(100vh - 70px);
        margin: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .delete-card {
        background: white;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 550px;
        text-align: center;
        border: 1px solid #fee2e2;
    }

    .info-preview {
        background: #f1f5f9;
        border-radius: 16px;
        padding: 15px;
        margin-bottom: 25px;
        border-left: 4px solid #ef4444;
        text-align: left;
    }
</style>

<div class="container-fluid p-0">
    <div class="admin-delete-wrapper">
        <div class="delete-card">
            <div class="mb-4 text-danger animated pulse infinite" style="font-size: 5rem;">
                <i class="fa-solid fa-circle-exclamation"></i>
            </div>

            <h3 class="fw-bold text-dark mb-2">Xác nhận xóa khóa học?</h3>
            <p class="text-secondary mb-4">
                Hành động này sẽ xóa vĩnh viễn dữ liệu và không thể hoàn tác.
            </p>

            <div class="info-preview">
                <div class="small text-uppercase fw-bold text-secondary">Tên khóa học:</div>
                <div class="fw-bold text-dark mb-2">@Model.TenKhoaHoc</div>
                
                <div class="row">
                    <div class="col-6">
                        <div class="small text-uppercase fw-bold text-secondary">Danh mục:</div>
                        <div class="text-dark">@(Model.DanhMuc?.TenDanhMuc ?? "Chưa phân loại")</div>
                    </div>
                    <div class="col-6">
                        <div class="small text-uppercase fw-bold text-secondary">Học phí:</div>
                        <div class="text-primary fw-bold">@Model.GiaTien.ToString("N0") VNĐ</div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                
                <div class="d-flex gap-3 justify-content-center">
                    <a asp-action="Index" class="btn btn-light px-4 py-2 rounded-pill border fw-bold text-secondary">
                        Hủy bỏ
                    </a>
                    <button type="submit" class="btn btn-danger px-4 py-2 rounded-pill fw-bold shadow-lg">
                        <i class="fa-solid fa-trash-can me-2"></i> Đồng ý xóa
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>