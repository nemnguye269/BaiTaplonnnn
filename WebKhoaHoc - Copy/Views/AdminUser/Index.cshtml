@using WebKhoaHoc.Models
@model IEnumerable<UserRoleViewModel>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid py-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Quản lý người dùng</h2>
            <p class="text-muted small">Danh sách tất cả tài khoản trong hệ thống</p>
        </div>
        <div class="badge bg-primary rounded-pill px-3 py-2">Total: @Model.Count()</div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-uppercase small fw-bold">
                            <th class="ps-4 py-3 border-0">Thành viên</th>
                            <th class="border-0">Email</th>
                            <th class="border-0">Vai trò</th>
                            <th class="border-0 text-center">Trạng thái</th>
                            <th class="text-center border-0">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var user = item.User;
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="position-relative">
                                            <img src="https://ui-avatars.com/api/?name=@(user.HoTen ?? user.UserName)&background=4361ee&color=fff" 
                                                 class="rounded-circle shadow-sm" width="40" height="40">
                                        </div>
                                        <div class="ms-3">
                                            <div class="fw-bold text-dark">@(user.HoTen ?? "N/A")</div>
                                            @* FIX LỖI SUBSTRING TẠI ĐÂY *@
                                            <small class="text-muted font-monospace" style="font-size: 0.75rem;">
                                                ID: @(user.Id.Length > 8 ? user.Id.Substring(0, 8) : user.Id)
                                            </small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-secondary small">@user.Email</span>
                                </td>
                                <td>
                                    @foreach (var role in item.Roles)
                                    {
                                        var roleClass = role == "Admin" ? "bg-soft-danger text-danger" : 
                                                       role == "GiangVien" ? "bg-soft-warning text-warning" : "bg-soft-info text-info";
                                        <span class="badge @roleClass rounded-pill me-1">@role</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (user.EmailConfirmed)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-3">Locked</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <form asp-action="ToggleLock" asp-route-id="@user.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm @(user.EmailConfirmed ? "btn-outline-danger" : "btn-outline-success") rounded-pill px-3">
                                            <i class="fa-solid @(user.EmailConfirmed ? "fa-user-slash" : "fa-user-check") me-1"></i>
                                            @(user.EmailConfirmed ? "Khóa" : "Mở")
                                        </button>
                                    </form>
                                    <a class="btn btn-sm btn-light rounded-circle ms-1"><i class="fa-solid fa-pen-to-square"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-info { background-color: #e0f2fe; color: #0369a1; }
    .bg-soft-danger { background-color: #fee2e2; color: #991b1b; }
    .bg-soft-warning { background-color: #fef3c7; color: #92400e; }
    .table-hover tbody tr:hover { background-color: #f8fafc; }
    .rounded-4 { border-radius: 1rem !important; }
</style>